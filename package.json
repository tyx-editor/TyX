{
  "name": "tyx",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "bun run prebuild",
    "dev": "vite",
    "dev:app": "bun run predev && tauri dev",
    "prebuild": "wasm-pack build crates/tyx-converters-wasm --target web --out-dir ../../src/converters",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prettier": "prettier",
    "build-web": "echo 'export * from \"./web\"' > src/backend/index.ts && bun run build && echo 'export * from \"./tauri\"' > src/backend/index.ts",
    "deploy": "bun run build-web && netlify deploy -d dist --prod --no-build",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\"",
    "schema": "bun scripts/create-json-schemas.ts && prettier -w schemas",
    "test": "wdio run wdio.conf.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lexical/code": "^0.43.0",
    "@lexical/react": "^0.43.0",
    "@mantine/core": "^9.0.2",
    "@mantine/hooks": "^9.0.2",
    "@mantine/modals": "^9.0.2",
    "@mantine/notifications": "^9.0.2",
    "@myriaddreamin/typst-ts-web-compiler": "^0.6.0",
    "@myriaddreamin/typst.ts": "^0.6.0",
    "@tabler/icons-react": "^3.41.1",
    "@tauri-apps/api": "~2.10.1",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "i18next": "^26.0.5",
    "lexical": "^0.43.0",
    "mathlive": "^0.109.1",
    "mousetrap": "^1.6.5",
    "mousetrap-global-bind": "^1.1.0",
    "mousetrap-record": "^1.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.4",
    "tex2typst": "^0.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.12",
    "@types/jsdom": "^28.0.1",
    "@types/mousetrap": "^1.6.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "netlify-cli": "^24.11.3",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.4",
    "wasm-pack": "^0.14.0"
  },
  "prettier": {
    "semi": false
  }
}
